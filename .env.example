# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=odoo_integration
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# Flask Configuration
FLASK_SECRET_KEY=change-this-to-a-random-secret-key
FLASK_DEBUG=false

# Auto-refresh interval in seconds (for the dashboard)
REFRESH_INTERVAL=30
