# Oracle Database Configuration
DB_HOST=193.122.68.27
DB_PORT=1521
DB_SERVICE_NAME=TestDB_jed1sw.dbsubnet.testvcn.oraclevcn.com
DB_USER=SYS
DB_PASSWORD=your_db_password
DB_MODE=SYSDBA

# Oracle Instant Client / Thick mode
# Required when the database uses Native Network Encryption (NNE)
# or when connecting as SYS with SYSDBA privileges.
# Set to the directory containing the Oracle Instant Client libraries.
# Examples:
#   Linux:   /opt/oracle/instantclient_21_12
#   macOS:   /Users/you/instantclient_21_12
#   Windows: C:\oracle\instantclient_21_12
# Leave empty to auto-detect via ORACLE_HOME or system paths.
ORACLE_CLIENT_PATH=

# Optional: set ORACLE_HOME if Oracle Client or full Oracle is installed.
# ORACLE_HOME=/opt/oracle/product/21c/dbhomeXE

# Optional: set TNS_ADMIN to point to a directory containing tnsnames.ora
# and sqlnet.ora if they are not in the default location.
# TNS_ADMIN=/opt/oracle/network/admin

# Flask Configuration
FLASK_SECRET_KEY=change-this-to-a-random-secret-key
FLASK_DEBUG=false

# Auto-refresh interval in seconds (for the dashboard)
REFRESH_INTERVAL=30
